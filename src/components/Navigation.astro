---
import type { MenuLinks } from '@/types'

interface Props {
  links: MenuLinks
  label: string
  class?: string
  isToggleable?: boolean
}

const { links, label, isToggleable = false, class: className } = Astro.props
---
<nav 
  class:list={["navigation", className]}
  aria-label={label} 
  data-nav={isToggleable ? true : undefined}
  data-state={isToggleable ? "closed" : undefined}
>
  <ul class="menu-list">
    {links.map((link) => (
      <li class="menu-item">
        <a href={link.path} class="menu-link">{link.title}</a>
      </li>
    ))}
  </ul>
</nav>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .header-navigation {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-height: 100svh;
    position: fixed;
    inset: 0;
    width: 100svw;
    background-color: var(--color-bg);
    transform: translateX(100%);
    transition: transform var(--transition-duration) cubic-bezier(.6,0,.4,1);

    &[data-state="open"] {
      transform: translateX(0);
      overflow-y: auto;
    }

    @include at(xl) {
      position: relative;
      transform: none;
    }
  }
  
  .menu-list {    
    padding-left: 0;
    list-style: none;
    margin-block: 0;
    text-align: end;

    @include at(xl) {
      display: flex;
      justify-content: end;
    }
  }

  .menu-item:last-child {
    .menu-link {
      background-color: var(--color-primary);
      color: var(--color-bg);
      border-radius: var(--border-radius);
      margin-top: var(--space-xs);

      @include at(xl) {
        margin: 0;
      }
    }
  }

  .menu-link {
    font-size: var(--step-3);
    font-weight: var(--font-regular);
    color: var(--color-text);
    line-height: 1.3;
    display: block;
    padding: var(--space-2xs) var(--space-s);
    width: fit-content;
    margin-left: auto;
    margin-right: var(--space-s);
    text-decoration: none;

    @include at(xl) {
      font-size: var(--step-0);
      margin-right: 0;
    }
  }
</style>